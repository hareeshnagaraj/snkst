      "padding": "0px",
      "textSample": "Hi, I’m Ludo Welcome to this healing space I’m a yoga teacher with an incredible passion for the way our bodies move. My classes are designed to achieve strength and flexibility, both in the body and in the mind, combining harmonious movements with specific breathing techniques. ",
      "images": [
        {
          "src": "https://images.squarespace-cdn.com/content/v1/5f4e6ca4d96a2e7c741e1dbe/1599561469103-8987Z4G06750N95Q5D6F/online-hatha-yoga-classes?format=500w",
          "alt": "online-hatha-yoga-classes",
          "w": 480,
          "h": 720
        },
        {
          "src": "https://images.squarespace-cdn.com/content/v1/5f4e6ca4d96a2e7c741e1dbe/1599047507685-XXO1U1SODXSX9F52QLYP/online-dynamic-yoga-classes?format=500w",
